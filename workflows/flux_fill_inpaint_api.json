{
  "_note": "ComfyUI API-format graph for real GPU background inpainting with FLUX.1 Fill dev (quantized GGUF, no LoRA). Inputs: source image node 5 and binary removal mask node 6; white mask pixels are regenerated. Output node 14 saves RGB. src/qwen_worker.py::flux_inpaint uploads both inputs, patches titled nodes, submits /prompt, polls /history, and downloads the output. Required: ComfyUI-GGUF for UnetLoaderGGUF plus the Q6_K Fill GGUF, fp8 T5, CLIP-L, and Flux VAE installed by scripts/setup_flux_inpaint.ps1. Model filenames can be overridden through inpaint.comfy.models. Guidance/steps/cfg are patched from config. If node names differ on the RTX ComfyUI build, edit this workflow and rerun the runtime smoke test.",
  "1": {
    "class_type": "UnetLoaderGGUF",
    "inputs": { "unet_name": "flux1-fill-dev-Q6_K.gguf" },
    "_meta": { "title": "flux_fill_unet_gguf" }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "t5xxl_fp8_e4m3fn.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    },
    "_meta": { "title": "flux_text_encoders" }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "ae.safetensors" },
    "_meta": { "title": "flux_vae" }
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": { "image": "flux_source.png" },
    "_meta": { "title": "source_image" }
  },
  "6": {
    "class_type": "LoadImage",
    "inputs": { "image": "flux_mask.png" },
    "_meta": { "title": "mask_image" }
  },
  "7": {
    "class_type": "ImageToMask",
    "inputs": { "image": ["6", 0], "channel": "red" },
    "_meta": { "title": "mask_to_channel" }
  },
  "8": {
    "class_type": "CLIPTextEncode",
    "inputs": { "clip": ["2", 0], "text": "" },
    "_meta": { "title": "positive_prompt" }
  },
  "9": {
    "class_type": "FluxGuidance",
    "inputs": { "conditioning": ["8", 0], "guidance": 30.0 },
    "_meta": { "title": "flux_guidance" }
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": { "clip": ["2", 0], "text": "" },
    "_meta": { "title": "negative_prompt" }
  },
  "11": {
    "class_type": "InpaintModelConditioning",
    "inputs": {
      "positive": ["9", 0],
      "negative": ["10", 0],
      "vae": ["3", 0],
      "pixels": ["5", 0],
      "mask": ["7", 0],
      "noise_mask": true
    },
    "_meta": { "title": "fill_conditioning" }
  },
  "12": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 8,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["11", 0],
      "negative": ["11", 1],
      "latent_image": ["11", 2]
    },
    "_meta": { "title": "ksampler_8step" }
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["12", 0], "vae": ["3", 0] },
    "_meta": { "title": "decode" }
  },
  "14": {
    "class_type": "SaveImage",
    "inputs": { "images": ["13", 0], "filename_prefix": "flux_inpaint" },
    "_meta": { "title": "save_inpaint" }
  }
}
