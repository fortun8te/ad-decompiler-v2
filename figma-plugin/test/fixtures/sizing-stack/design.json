          "text": "Resize me and the layout still behaves.",
          "style": {
            "fontFamily": "Arial",
            "fontSize": 14,
            "color": "#444444",
            "autoResize": "HEIGHT",
            "multiline": true
          },
          "sizing": {
            "w": "fill",
            "h": "hug"
          }
        },
        {
          "id": "divider",
          "type": "shape",
          "shape_kind": "rect",
          "name": "divider",
          "box": {
            "x": 20,
            "y": 124,
            "w": 240,
            "h": 2
          },
          "fill": {
            "kind": "flat",
            "color": "#cccccc"
          },
          "sizing": {
            "w": "fill",
            "h": "fixed"
          }
        },
        {
          "id": "cta",
          "type": "group",
          "name": "cta",
          "box": {
            "x": 20,
            "y": 142,
            "w": 140,
            "h": 44
          },
          "meta": {
            "role": "button"
          },
          "sizing": {
            "w": "hug",
            "h": "hug"
