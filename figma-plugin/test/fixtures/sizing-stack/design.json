        "h": 206
      },
      "fill": {
        "kind": "flat",
        "color": "#ffffff"
      },
      "radius": 12,
      "layout": {
        "mode": "VERTICAL",
        "gap": 16,
        "padding": {
          "top": 20,
          "right": 20,
          "bottom": 20,
          "left": 20
