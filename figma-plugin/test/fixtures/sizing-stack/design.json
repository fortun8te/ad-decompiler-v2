              "radius": 22
            },
            {
              "id": "cta-label",
              "type": "text",
              "name": "cta-label",
              "box": {
                "x": 20,
                "y": 12,
                "w": 100,
                "h": 20
              },
              "text": "Buy now",
              "style": {
                "fontFamily": "Arial",
                "fontSize": 16,
                "color": "#ffffff",
                "align": "CENTER"
