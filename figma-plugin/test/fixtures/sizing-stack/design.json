      },
      "sizing": {
        "w": "fixed",
        "h": "hug"
      },
      "children": [
        {
          "id": "headline",
          "type": "text",
          "name": "headline",
          "box": {
            "x": 20,
            "y": 20,
            "w": 240,
            "h": 28
          },
          "text": "Sizing Stack",
          "style": {
            "fontFamily": "Arial",
            "fontSize": 18,
            "color": "#111111",
            "autoResize": "WIDTH_AND_HEIGHT"
          },
          "sizing": {
            "w": "hug",
            "h": "hug"
          }
        },
        {
          "id": "body",
          "type": "text",
          "name": "body",
          "box": {
            "x": 20,
            "y": 64,
            "w": 240,
            "h": 44
