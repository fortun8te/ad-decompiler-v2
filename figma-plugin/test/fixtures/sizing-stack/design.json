{
  "id": "sizing-stack",
  "name": "sizing-stack",
  "canvas": {
    "w": 360,
    "h": 320
  },
  "schema_version": 2,
  "meta": {
    "coordinate_space": "local"
  },
  "layers": [
    {
      "id": "card",
